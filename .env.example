# ===============================================
# 多语言预训练模型演示系统 - 环境配置文件模板
# ===============================================
# 复制此文件为 .env，然后填入你的实际 API 密钥

# ===============================================
# Stage 3 & Stage 4: 需要云端 API 的模型
# ===============================================

# OpenAI API - 用于 GPT-3 和 GPT-4o 模型
OPENAI_API_KEY=sk-...

# Google API - 用于 PaLM/Gemini 相关模型调用
GOOGLE_API_KEY=

# Anthropic API - 用于 Claude 模型
ANTHROPIC_API_KEY=sk-ant-...

# ===============================================
# Stage 4: 国产和特化大模型 API（可选）
# ===============================================

# 阿里云百炼 API - 用于 Qwen 系列模型
# 获取途径: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 兼容旧变量名（可选）
QWEN_API_KEY=

# 可选：Qwen API 端点（如使用私有部署版本）
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===============================================
# 本地模块和可选配置
# ===============================================

# HuggingFace 模型缓存目录（强烈建议设置，避免重复下载）
HF_HOME=./models

# 项目统一模型缓存目录（与 HF_HOME 保持一致）
MODEL_CACHE_DIR=./models

# 本地模型精度设置（float32/float16，建议 float32 以确保兼容性）
MODEL_DTYPE=float32

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# ===============================================
# 说明
# ===============================================
# ✓ 本地完整调用的模型（无需 API）：
#   Stage 1: word2vec, ELMo, Transformer, BERT, mBERT
#   Stage 2: XLM, XLM-R
#   Stage 3: mBART, mT5, BLOOM, XGLM
#   Stage 4: Qwen (可本地部署版本), LLaMA, NLLB, MADLAD-400, Aya
#
# ✓ 需要 API 的模型（需配置上述密钥）：
#   Stage 3: GPT-3, PaLM (需 Google API)
#   Stage 4: Qwen (API 版本)
#
# 提示：Unicoder 与 PaLM 无开源权重，当前实现会直接报错说明原因。
